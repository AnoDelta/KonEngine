{
    "name": "KonScript",
    "scopeName": "source.konscript",
    "fileTypes": ["ks"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#preprocessor" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#builtins" },
        { "include": "#namespaces" },
        { "include": "#booleans" },
        { "include": "#nulls" },
        { "include": "#functions" },
        { "include": "#typedefs" },
        { "include": "#operators" },
        { "include": "#labels" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.konscript",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.konscript",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "name": "keyword.other.todo.konscript",
                            "match": "\\b(TODO|FIXME|NOTE|HACK|XXX)\\b"
                        }
                    ]
                }
            ]
        },
        "preprocessor": {
            "patterns": [
                {
                    "name": "meta.preprocessor.konscript",
                    "begin": "^\\s*(#include)",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.import.konscript" }
                    },
                    "end": "$",
                    "patterns": [
                        {
                            "name": "string.quoted.other.lt-gt.konscript",
                            "match": "<[^>]+>"
                        },
                        {
                            "name": "string.quoted.double.konscript",
                            "match": "\"[^\"]+\""
                        }
                    ]
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.konscript",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.konscript",
                    "match": "\\\\[ntr\"\\\\0]"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.konscript",
                    "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
                },
                {
                    "name": "constant.numeric.float.konscript",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.konscript",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.konscript",
                    "match": "\\b(if|else|while|loop|for|in|break|continue|switch|case|default|return)\\b"
                },
                {
                    "name": "keyword.declaration.konscript",
                    "match": "\\b(let|mut|const|func|node|struct|enum|class|pub|extends|as|spawn|wait)\\b"
                }
            ]
        },
        "types": {
            "name": "support.type.konscript",
            "match": "\\b(I8|I16|I32|I64|U8|U16|U32|U64|F32|F64|Bool|str|String|Vec2|void)\\b"
        },
        "builtins": {
            "name": "support.function.konscript",
            "match": "\\b(InitWindow|WindowShouldClose|Present|PollEvents|ClearBackground|SetTargetFPS|GetDeltaTime|DrawRectangle|DrawCircle|DrawLine|DrawTexture|DrawText|KeyDown|KeyPressed|KeyReleased|MouseDown|MousePressed|GetMouseX|GetMouseY|GetNode|GetChild|Emit|Connect|Print|ToString|BeginCamera2D|EndCamera2D|PlaySound|PlayMusic|StopSound|StopMusic|LoadTexture|UnloadTexture|DebugMode|IsDebugMode)\\b"
        },
        "namespaces": {
            "name": "support.constant.konscript",
            "match": "\\b(Key|Mouse|Gamepad)::[A-Za-z_][A-Za-z0-9_]*"
        },
        "booleans": {
            "name": "constant.language.boolean.konscript",
            "match": "\\b(true|false)\\b"
        },
        "nulls": {
            "name": "constant.language.null.konscript",
            "match": "\\b(null|None|Some)\\b"
        },
        "functions": {
            "name": "entity.name.function.konscript",
            "match": "\\bfunc\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(",
            "captures": {
                "1": { "name": "entity.name.function.konscript" }
            }
        },
        "typedefs": {
            "match": "\\b(node|struct|enum|class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.konscript" },
                "2": { "name": "entity.name.type.konscript" }
            }
        },
        "operators": {
            "name": "keyword.operator.konscript",
            "match": "(\\.\\.=|\\.\\.|->|=>|\\?\\?|\\?\\.|::|[-+*/%=<>!&|?])"
        },
        "labels": {
            "name": "entity.name.label.konscript",
            "match": "'[a-zA-Z_][a-zA-Z0-9_]*"
        }
    }
}
